# ===== Application Configuration =====
APP_ENV=development
APP_NAME=LangGraph Enterprise Agent Platform
APP_DEBUG=true

# ===== LLM Configuration (Replace with company AI platform URL) =====
LLM_API_BASE_URL=http://your-company-ai-platform/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL_NAME=qwen-turbo
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096
LLM_REQUEST_TIMEOUT=60
LLM_MAX_RETRIES=3

# ===== Database Configuration =====
# Development: Uses SQLite by default (no configuration needed)
# Production: Set POSTGRES_DSN or DATABASE_URL for PostgreSQL

# Option 1: PostgreSQL DSN format (recommended)
POSTGRES_DSN=postgresql://chatbot_user:password@localhost:5432/chatbot_db

# Option 2: Standard DATABASE_URL format
# DATABASE_URL=postgresql://chatbot_user:password@localhost:5432/chatbot_db

# Development: Custom SQLite path (optional, defaults to ./data/chatbot_dev.db)
# SQLITE_PATH=./data/chatbot_dev.db

# Connection pool settings (PostgreSQL only)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Enable SQL query logging (development only, set to "true" for debugging)
DB_ECHO=false

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# ===== API Service Configuration =====
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true
API_PREFIX=/api/v1
API_SECRET_KEY=change-me-in-production-use-strong-random-string

# ===== LDAP / Active Directory Configuration =====
LDAP_SERVER_URL=ldaps://ad.company.com
LDAP_BASE_DN=DC=company,DC=com
LDAP_DOMAIN=COMPANY
LDAP_USE_SSL=true
LDAP_AUTH_METHOD=ntlm
LDAP_BIND_DN=CN=service_account,OU=Service Accounts,DC=company,DC=com
LDAP_BIND_PASSWORD=your-service-account-password

# ===== JWT Configuration =====
JWT_SECRET=change-this-to-a-strong-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== Control-M Configuration (Multi-Region Support) =====

# Legacy single-region configuration (for backward compatibility)
CONTROLM_BASE_URL=http://controlm-server:8443/api/v1
CONTROLM_USERNAME=ctm_api_user
CONTROLM_PASSWORD=your-controlm-password
CONTROLM_VERIFY_SSL=false
CONTROLM_TIMEOUT=30

# Multi-region configuration (recommended for production)
# Format: CONTROLM_REGION_<REGION_NAME>_<SETTING>=value
# Region names should be lowercase with hyphens (e.g., us-east, eu-west)

# US East Region
CONTROLM_REGION_US_EAST_NAME=us-east
CONTROLM_REGION_US_EAST_BASE_URL=https://controlm-us.company.com/api/v1
CONTROLM_REGION_US_EAST_USERNAME=ctm_us_user
CONTROLM_REGION_US_EAST_PASSWORD=your-us-password
CONTROLM_REGION_US_EAST_DESCRIPTION="US East region - handles North America operations"

# Europe West Region
CONTROLM_REGION_EU_WEST_NAME=eu-west
CONTROLM_REGION_EU_WEST_BASE_URL=https://controlm-eu.company.com/api/v1
CONTROLM_REGION_EU_WEST_USERNAME=ctm_eu_user
CONTROLM_REGION_EU_WEST_PASSWORD=your-eu-password
CONTROLM_REGION_EU_WEST_DESCRIPTION="Europe West region - handles EMEA operations"

# Asia Pacific Region
CONTROLM_REGION_AP_SOUTHEAST_NAME=ap-southeast
CONTROLM_REGION_AP_SOUTHEAST_BASE_URL=https://controlm-ap.company.com/api/v1
CONTROLM_REGION_AP_SOUTHEAST_USERNAME=ctm_ap_user
CONTROLM_REGION_AP_SOUTHEAST_PASSWORD=your-ap-password
CONTROLM_REGION_AP_SOUTHEAST_DESCRIPTION="Asia Pacific region - handles APAC operations"

# Default region to use when not specified
CONTROLM_DEFAULT_REGION=us-east

# Enable LLM-based region detection (true/false)
CONTROLM_ENABLE_REGION_DETECTION=true

# ===== RAG Knowledge Base Configuration (Group AI Platform) =====
RAG_API_URL=http://your-group-ai-platform/rag/search
RAG_API_KEY=your-rag-api-key-here
RAG_REQUEST_TIMEOUT=30
RAG_DEFAULT_TOP_K=5
RAG_MIN_RELEVANCE_SCORE=0.7

# ===== LLM Wiki Configuration (Group AI Platform) =====
WIKI_API_URL=http://your-group-ai-platform/wiki/query
WIKI_API_KEY=your-wiki-api-key-here
WIKI_REQUEST_TIMEOUT=30
WIKI_EXACT_MATCH_DEFAULT=false
WIKI_MAX_CONTENT_LENGTH=5000

# ===== Monitoring Configuration =====
LOG_LEVEL=INFO
LOG_FORMAT=text
ENABLE_PROMETHEUS=true
PROMETHEUS_PORT=9090
