{
  "dashboard": {
    "id": null,
    "uid": "chatbot-api-monitoring",
    "title": "Chatbot API Monitoring Dashboard",
    "tags": ["chatbot", "api", "production"],
    "timezone": "browser",
    "schemaVersion": 30,
    "version": 1,
    "refresh": "30s",
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Request Rate & Error Rate",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "rate(agent_requests_total[5m])",
            "legendFormat": "{{endpoint}} - {{status}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "red", "value": 100}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Request Latency (P95)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(agent_request_duration_seconds_bucket[5m]))",
            "legendFormat": "{{endpoint}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "id": 3,
        "title": "Authentication Failures",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "rate(authentication_failures_total[5m])",
            "legendFormat": "{{endpoint}} - {{reason}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "failures/sec",
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 5},
                {"color": "red", "value": 10}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Rate Limit Violations",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
        "targets": [
          {
            "expr": "rate(rate_limit_exceeded_total[5m])",
            "legendFormat": "{{endpoint}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "violations/sec"
          }
        }
      },
      {
        "id": 5,
        "title": "Active Sessions & API Keys",
        "type": "stat",
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
        "targets": [
          {
            "expr": "agent_active_sessions",
            "legendFormat": "Active Sessions"
          },
          {
            "expr": "active_api_keys_total",
            "legendFormat": "Active API Keys"
          }
        ]
      },
      {
        "id": 6,
        "title": "LLM Performance",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(llm_call_duration_seconds_bucket[5m]))",
            "legendFormat": "{{model}} - {{operation}} (P95)"
          },
          {
            "expr": "rate(llm_calls_total[5m])",
            "legendFormat": "{{model}} - calls/sec"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "id": 7,
        "title": "LLM Token Usage",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "rate(llm_tokens_total[5m])",
            "legendFormat": "{{model}} - {{type}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "tokens/sec"
          }
        }
      },
      {
        "id": 8,
        "title": "Wiki Knowledge Base Stats",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 24},
        "targets": [
          {
            "expr": "wiki_articles_total",
            "legendFormat": "Total Articles"
          }
        ]
      },
      {
        "id": 9,
        "title": "Wiki Feedback (Positive vs Negative)",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 24},
        "targets": [
          {
            "expr": "sum(rate(wiki_feedback_total{is_positive=\"true\"}[1h]))",
            "legendFormat": "Positive"
          },
          {
            "expr": "sum(rate(wiki_feedback_total{is_positive=\"false\"}[1h]))",
            "legendFormat": "Negative"
          }
        ]
      },
      {
        "id": 10,
        "title": "Low Confidence Wiki Alerts",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
        "targets": [
          {
            "expr": "rate(wiki_low_confidence_alerts_total[1h])",
            "legendFormat": "{{entry_id}}"
          }
        ]
      },
      {
        "id": 11,
        "title": "System Resources - Memory",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
        "targets": [
          {
            "expr": "process_memory_bytes / 1024 / 1024",
            "legendFormat": "RSS Memory (MB)"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes",
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 536870912},
                {"color": "red", "value": 1073741824}
              ]
            }
          }
        }
      },
      {
        "id": 12,
        "title": "System Resources - CPU",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32},
        "targets": [
          {
            "expr": "process_cpu_percent",
            "legendFormat": "CPU Usage %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "max": 100,
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 60},
                {"color": "red", "value": 80}
              ]
            }
          }
        }
      },
      {
        "id": 13,
        "title": "User Registrations & Logins",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 40},
        "targets": [
          {
            "expr": "rate(user_registrations_total[1h])",
            "legendFormat": "Registrations/sec"
          },
          {
            "expr": "rate(user_logins_total{status=\"success\"}[5m])",
            "legendFormat": "Successful Logins/sec"
          },
          {
            "expr": "rate(user_logins_total{status=\"failure\"}[5m])",
            "legendFormat": "Failed Logins/sec"
          }
        ]
      },
      {
        "id": 14,
        "title": "Skill Execution Performance",
        "type": "table",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 40},
        "targets": [
          {
            "expr": "rate(skill_executions_total[5m])",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {},
              "indexByName": {},
              "renameByName": {
                "Value": "Executions/sec",
                "skill_name": "Skill",
                "status": "Status"
              }
            }
          }
        ]
      }
    ],
    "templating": {
      "list": [
        {
          "name": "endpoint",
          "type": "query",
          "datasource": "Prometheus",
          "query": "label_values(agent_requests_total, endpoint)"
        },
        {
          "name": "model",
          "type": "query",
          "datasource": "Prometheus",
          "query": "label_values(llm_calls_total, model)"
        }
      ]
    },
    "annotations": {
      "list": [
        {
          "name": "Deployments",
          "datasource": "-- Grafana --",
          "enable": true,
          "iconColor": "blue",
          "expr": "deployments"
        }
      ]
    }
  },
  "overwrite": true
}
